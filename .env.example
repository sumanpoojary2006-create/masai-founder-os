# Copy this file to `.env.local` and fill in your own values.

OPENROUTER_API_KEY=replace_with_your_openrouter_key
DATABASE_URL=
AI_COMPANY_HOST=127.0.0.1
AI_COMPANY_PORT=8000
AI_COMPANY_DB_PATH=masai_founder_os.db
AI_COMPANY_WORKFLOW_DELAY=0.35
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Masai Founder OS
SMTP_USE_TLS=true
SMTP_USE_SSL=false
